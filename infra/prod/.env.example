COMPOSE_PROJECT_NAME=fintellectus-tanstackdb
APP_CONTAINER_NAME=fintellectus_tanstackdb_app
APP_CONTAINER_NAME_PREFIX=fintellectus_tanstackdb_app
APP_IMAGE_PIN_CONTAINER_PREFIX=fintellectus_tanstackdb_app_image_pin
APP_RELEASE_PREFIX=prod
APP_DEPLOY_WORKTREE_ROOT=/opt/dev/erudio_app/react-hono-tanstackdb-duckdb/.deploy-worktrees
APP_DEPLOY_KEEP_FAILED_WORKTREE=0
APP_DEPLOY_FAILED_WORKTREE_RETENTION_DAYS=7

APP_DATA_HOST_PATH=/opt/dev/erudio_app/app_data
APP_BIND_HOST=127.0.0.1
APP_BIND_PORT=3200
APP_BLUE_BIND_PORT=3200
APP_GREEN_BIND_PORT=3201
CADDY_SITES_HOST_PATH=/opt/dev/erudio_app/caddy/sites
CADDY_SITE_BASENAME=fintellectus-tanstackdb.Caddyfile
CADDY_SITE_PATH=${CADDY_SITES_HOST_PATH}/${CADDY_SITE_BASENAME}
CADDY_RELOAD_COMMAND="systemctl reload caddy"

APP_DOMAIN=fintellectus-tanstackdb.206.168.212.173.sslip.io
APP_PUBLIC_URL=https://fintellectus-tanstackdb.206.168.212.173.sslip.io
APP_HEALTHCHECK_PATH=/healthz

APP_IMAGE=fintellectus-tanstackdb-app:latest
API_PORT=3000
POSTGRES_NETWORK=fintellectus_default
ZERO_UPSTREAM_DB=postgresql://user:password@postgres:5432/postgres
ZERO_AUTH_SECRET=secretkey
DUCKDB_FORCE_EXECUTION=off

DUCKDB_PATH=/app_data/TR_05_DB/TR_05_DUCKDB_FILE.duckdb
SEARCH_INDEX_PATH=/app_data/TR_05_DB/TR_05_WEB_SEARCH_INDEX/search_index.json

DEPLOY_APP_DIR=/opt/dev/erudio_app/react-hono-tanstackdb-duckdb
